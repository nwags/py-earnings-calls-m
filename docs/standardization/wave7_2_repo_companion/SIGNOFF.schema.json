{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/m-cache/consumer-signoff.schema.json",
  "type": "object",
  "required": [
    "candidate_tag",
    "repo",
    "release_role",
    "pin_confirmed",
    "validation_status",
    "signoff_state",
    "blockers",
    "warnings",
    "rollback_ready"
  ],
  "properties": {
    "candidate_tag": { "type": "string" },
    "repo": { "type": "string" },
    "release_role": { "type": "string" },
    "pin_confirmed": { "type": "boolean" },
    "validation_status": { "type": "string" },
    "signoff_state": {
      "type": "string",
      "enum": ["pass", "warn", "block"]
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rollback_ready": { "type": "boolean" }
  },
  "additionalProperties": false
}
